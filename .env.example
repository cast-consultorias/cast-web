# ─────────────────────────────────────────────────────────────
# CAST Consultorías — Variables de entorno
# Copiar este archivo a .env y rellenar los valores reales.
# NUNCA commitear .env al repositorio.
# En Netlify: Site settings > Environment variables
# ─────────────────────────────────────────────────────────────

# Google Apps Script (formulario de contacto general — si aplica)
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/TU_URL_AQUI/exec

# ── Supabase — Radiografía CAST™ ──────────────────────────────
# Obtener en: Supabase Dashboard > Project Settings > API
# URL del proyecto (ej: https://xyzabc.supabase.co)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Anon key (clave pública — solo permite INSERT en leads_radiografia)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── n8n Webhook (opcional) ────────────────────────────────────
# Si está definida, el formulario envía un POST con el payload completo
# tras cada insert exitoso. Si bandera_bp05 = true, incluye prioridad: "BP05_ALERTA".
# Dejar vacía para deshabilitar.
VITE_N8N_WEBHOOK_URL=
